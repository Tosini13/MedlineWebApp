# ---------------------------------------------------------------------------
# MedlineWebApp environment variables
# Copy this file to `.env` and fill in the values from your Supabase project.
# NEVER commit the real `.env` file.
# ---------------------------------------------------------------------------

# Public Supabase config (safe to expose to the browser).
# Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Dashboard → Project Settings → API → API Keys → Publishable key (sb_publishable_...)
VITE_SUPABASE_KEY="sb_publishable_your-key-here"

# Server-only secret. Used exclusively by local seeding/admin scripts.
# Dashboard → Project Settings → API → API Keys → Secret key (sb_secret_...)
# MUST NOT be prefixed with VITE_ and MUST NOT be imported into client code.
SUPABASE_SECRET_KEY="sb_secret_your-key-here"

# Document upload constraints (server-enforced).
VITE_MAX_UPLOAD_MB="10"

# ---------------------------------------------------------------------------
# Legacy Firebase migration (server-only — never prefix with VITE_)
# Used by the account page migration UI and scripts/migrate-from-firebase.ts.
# Firebase Console → Project Settings → Service accounts → Generate new private key
# ---------------------------------------------------------------------------
# Path to the service-account JSON file (recommended for local dev):
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
# Or inline JSON (useful in CI; escape newlines in private_key as \n):
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# Optional override if your bucket name differs from the default:
# FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# ---------------------------------------------------------------------------
# Signup: reCAPTCHA + admin approval notifications (server-only unless noted)
# ---------------------------------------------------------------------------
VITE_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="onboarding@resend.dev"
ADMIN_NOTIFICATION_EMAIL="jakub.bartosik.work@gmail.com"

# ---------------------------------------------------------------------------
# Alternate names (supported as fallbacks):
#   VITE_SUPABASE_PUBLISHABLE_KEY — set by Vercel Supabase integration
#   VITE_SUPABASE_ANON_KEY        — legacy anon JWT
#   SUPABASE_SERVICE_ROLE_KEY     → use SUPABASE_SECRET_KEY instead
# ---------------------------------------------------------------------------
